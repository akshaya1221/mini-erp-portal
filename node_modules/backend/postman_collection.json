              "raw": "{\n  \"name\": \"Ramesh Shah\",\n  \"mobile\": \"9898989898\",\n  \"email\": \"ramesh@example.com\",\n  \"businessName\": \"Shah Steels\",\n  \"gstNumber\": \"29ABCDE1234F1Z5\",\n  \"customerType\": \"WHOLESALE\",\n  \"address\": \"Mumbai\",\n  \"status\": \"ACTIVE\",\n  \"followUpDate\": \"2026-07-30\",\n  \"notes\": \"Interested in steel structural beams\"\n}"
